# --- GitLab (push the work branch — write scope, NON-protected branches only) -------------
# A personal/project access token, scoped to NON-protected branches. Used only to push the
# sandbox work branch and by preflight.sh to verify push works. main is protected and is
# NEVER pushed. Leave blank to skip the GitLab check.
#
# Fine-grained tokens: on the Code permission grant BOTH `Download` (git fetch/clone/ls-remote)
# AND `Push` (git push). "Read" is API-level read and is NOT enough for git fetch — the missing
# `Code: Download` is the usual cause of a valid-but-403 token. Classic tokens: use `write_repository`.
GITLAB_TOKEN=glpat-<...>
OPENAI_API_KEY=