{
  "$schema": "https://opencode.ai/config.json",

  "provider": {
    "openhippo": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Open Hippo",
      "options": {
        "baseURL": "https://api.openhippo.io",
        "apiKey": "{env:OPENAI_API_KEY}"
      },
      "models": {
        "qwen/Qwen3.6-27B": {
          "name": "qwen/Qwen3.6-27B"
        }
      }
    }
  },

  "model": "openhippo/qwen/Qwen3.6-27B",

  "agent": {
    "deep": {
      "description": "Heavy reasoning / complex work",
      "model": "openhippo/qwen/Qwen3.6-27B"
    },
    "fast": {
      "description": "Quick edits / lightweight work",
      "model": "openhippo/qwen/Qwen3.6-27B"
    },
    "explorer": {
      "mode": "subagent",
      "description": "Use for reading files, searching the codebase, grepping, and gathering context. Delegate all file-exploration and lookup work here.",
      "model": "openhippo/qwen/Qwen3.6-27B"
    }
  }
}
